# Copy to .env and fill in. .env is gitignored.
OPENROUTER_API_KEY=sk-or-v1-...
# Model id passed to callModel. openrouter/free is the no-cost default.
JOBLOOPER_MODEL=openrouter/free
# Stop the loop once submitted >= this number.
JOBLOOPER_TARGET=1300
# Set to 1 to run without recording real submissions (safe testing).
DRY_RUN=0
# Path to the logged-in Chrome profile used for the browser bridge.
CHROME_PROFILE=/Users/mst/.playwright-chrome
# CDP endpoint of the running Chrome (opened with --remote-debugging-port=9222).
CDP_URL=http://127.0.0.1:9222
# Campaign data dir (tracker.json / applicant.json live here; state is continuous).
CAMPAIGN_DIR=/Users/mst/Downloads/job-search/job-apply
